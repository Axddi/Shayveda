# Neon/PostgreSQL connection string.
# Use the pooled URL for serverless deployments such as Vercel.
DATABASE_URL="postgresql://USER:PASSWORD@HOST.neon.tech/DBNAME?sslmode=require"
PORT=5000
JWT_SECRET="replace_me"
ADMIN_API_TOKEN="replace_me"

# Use rzp_test_* for testing and rzp_live_* after Razorpay account activation.
RAZORPAY_KEY_ID="rzp_live_xxxxx"
RAZORPAY_KEY_SECRET="replace_me"

SHIPROCKET_EMAIL="api-user@example.com"
SHIPROCKET_PASSWORD="replace_me"
SHIPROCKET_API_BASE="https://apiv2.shiprocket.in/v1/external"
SHIPROCKET_PICKUP_LOCATION="Home"
SHIPROCKET_PICKUP_CONTACT_NAME="Shayveda"
SHIPROCKET_PICKUP_EMAIL="support@shayveda.com"
SHIPROCKET_PICKUP_PHONE="9876543210"
SHIPROCKET_PICKUP_ADDRESS="Pickup street address"
SHIPROCKET_PICKUP_ADDRESS_2=""
SHIPROCKET_PICKUP_CITY="Panipat"
SHIPROCKET_PICKUP_STATE="Haryana"
SHIPROCKET_PICKUP_PINCODE="132103"
SHIPROCKET_AUTO_CREATE_PICKUP="false"
SHIPROCKET_PACKAGE_LENGTH_CM=10
SHIPROCKET_PACKAGE_BREADTH_CM=10
SHIPROCKET_PACKAGE_HEIGHT_CM=10
SHIPROCKET_PACKAGE_WEIGHT_KG=0.5

# AWS SES order confirmation email.
AWS_SES_REGION="ap-south-1"
AWS_ACCESS_KEY_ID="replace_me"
AWS_SECRET_ACCESS_KEY="replace_me"
ORDER_EMAIL_FROM="Shayveda <orders@yourdomain.com>"
ORDER_EMAIL_REPLY_TO="support@yourdomain.com"
